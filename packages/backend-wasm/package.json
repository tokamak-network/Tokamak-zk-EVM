{
  "name": "@tokamak-zk-evm/backend-wasm",
  "version": "0.0.0",
  "description": "Web-compatible Tokamak zk-EVM prover and verifier package scaffold.",
  "license": "GPL-3.0-or-later",
  "author": "Tokamak Network",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist/index.js",
    "dist/index.d.ts",
    "dist/libs",
    "dist/prover",
    "dist/tools",
    "dist/utils",
    "dist/verifier",
    "README.md",
    "LICENSE",
    "fixtures"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json --pretty false",
    "typecheck": "tsc -p tsconfig.json --pretty false --noEmit",
    "typecheck:scripts": "tsc --pretty false --noEmit --module NodeNext --moduleResolution NodeNext --target ES2022 --lib ES2022,DOM --types node scripts/check-binary-artifacts.ts scripts/check-fixtures.ts scripts/check-polynomial-fixtures.ts scripts/check-prover-witness.ts scripts/check-runtime-fixtures.ts scripts/check-verifier-browser.ts scripts/check-verifier-fixture.ts scripts/convert-artifacts.ts scripts/copy-fixtures.ts scripts/generate-format-specs.ts test/browser/verifier-entry.ts",
    "binary:check": "tsx scripts/check-binary-artifacts.ts",
    "bench:msm": "tsx src/tests/msm/bench-msm.ts",
    "fixtures:copy": "tsx scripts/copy-fixtures.ts fixtures/small/copy-manifest.json",
    "fixtures:check": "tsx scripts/check-fixtures.ts fixtures/small/manifest.json",
    "polynomial:check": "tsx scripts/check-polynomial-fixtures.ts",
    "prover:witness:check": "tsx scripts/check-prover-witness.ts",
    "runtime:check": "tsx scripts/check-runtime-fixtures.ts",
    "specs:check": "tsx scripts/generate-format-specs.ts --check",
    "specs:generate": "tsx scripts/generate-format-specs.ts",
    "verifier:browser:check": "tsx scripts/check-verifier-browser.ts",
    "verifier:check": "tsx scripts/check-verifier-fixture.ts",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@noble/hashes": "^1.8.0",
    "@tokamak-zk-evm/subcircuit-library": "latest",
    "ffjavascript": "^0.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.15.14",
    "esbuild": "^0.28.1",
    "playwright": "^1.61.1",
    "tsx": "^4.20.5",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=20"
  }
}
