{
  "name": "@tokamak-zk-evm/synthesizer-web",
  "version": "2.0.13",
  "description": "Browser-facing Tokamak zk-EVM synthesizer package with bundled subcircuit library assets.",
  "keywords": [
    "ethereum",
    "zkevm",
    "zero-knowledge",
    "zk-SNARK",
    "browser",
    "wasm",
    "synthesizer",
    "tokamak",
    "layer2",
    "tokamak-network"
  ],
  "homepage": "https://github.com/tokamak-network/Tokamak-zk-EVM/tree/main/packages/frontend/synthesizer/web-app#readme",
  "bugs": {
    "url": "https://github.com/tokamak-network/Tokamak-zk-EVM/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/tokamak-network/Tokamak-zk-EVM.git",
    "directory": "packages/frontend/synthesizer/web-app"
  },
  "license": "MIT OR Apache-2.0",
  "author": "Tokamak Network",
  "contributors": [
    "JehyukJang <https://github.com/JehyukJang>",
    "Ale Son <ale@tokamak.network>"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/types/web-app/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/web-app/src/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js"
    }
  },
  "files": [
    "dist",
    "build-metadata.json",
    "CHANGELOG.md",
    "README.md",
    "LICENSE-MIT",
    "LICENSE-APACHE",
    "NOTICE"
  ],
  "scripts": {
    "sync:changelog": "node ../../../../scripts/sync-package-changelog.mjs packages/frontend/synthesizer/web-app",
    "sync:bundled-subcircuit-module": "node scripts/generate-bundled-subcircuit-module.mjs",
    "build": "npm run typecheck && npm run build:package",
    "build:package": "npm run sync:changelog && npm run sync:bundled-subcircuit-module && node scripts/build-package.mjs",
    "typecheck": "npm run sync:bundled-subcircuit-module && tsc -p tsconfig.json --pretty false",
    "tsc": "npm run typecheck",
    "prepack": "npm run build:package"
  },
  "dependencies": {
    "@ethereumjs/block": "^10.0.0",
    "@ethereumjs/evm": "^10.0.0",
    "@ethereumjs/tx": "^10.0.0",
    "@ethereumjs/util": "^10.0.0",
    "@ethereumjs/vm": "^10.0.0",
    "@noble/curves": "1.9.7",
    "@tokamak-zk-evm/subcircuit-library": "^2.0.13",
    "@zk-kit/imt": "2.0.0-beta.8",
    "tokamak-l2js": "^0.1.3"
  },
  "devDependencies": {
    "@types/node": "^22.15.14",
    "esbuild": "^0.25.8",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=18"
  }
}
