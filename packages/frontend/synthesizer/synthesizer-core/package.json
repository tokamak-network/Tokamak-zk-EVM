{
  "name": "@tokamak-zk-evm/synthesizer-core",
  "version": "0.0.10",
  "description": "Environment-neutral core logic for the Tokamak zk-EVM synthesizer.",
  "homepage": "https://github.com/tokamak-network/tokamak-zk-evm/tree/main/packages/frontend/synthesizer/synthesizer-core#readme",
  "bugs": {
    "url": "https://github.com/tokamak-network/tokamak-zk-evm/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/tokamak-network/tokamak-zk-evm.git"
  },
  "license": "MIT OR Apache-2.0",
  "author": "Tokamak Network",
  "contributors": [
    "JehyukJang <https://github.com/JehyukJang>",
    "Ale Son <ale@tokamak.network>"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "npm run typecheck && npm run build:package",
    "build:package": "node scripts/build-package.mjs",
    "typecheck": "tsc -p tsconfig.json --pretty false --noEmit",
    "tsc": "npm run typecheck",
    "prepack": "npm run build:package"
  },
  "dependencies": {
    "@ethereumjs/block": "^10.0.0",
    "@ethereumjs/evm": "^10.0.0",
    "@ethereumjs/tx": "^10.0.0",
    "@ethereumjs/util": "^10.0.0",
    "@ethereumjs/vm": "^10.0.0",
    "@noble/curves": "1.9.7",
    "@zk-kit/imt": "2.0.0-beta.8",
    "tokamak-l2js": "^0.1.3"
  },
  "devDependencies": {
    "@types/node": "^22.15.14",
    "esbuild": "^0.25.8",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=18"
  }
}
