{
  "extends": "../../../config/monorepo-js/tsconfig.json",
  "compilerOptions": {
    "allowImportingTsExtensions": true,
    "emitDeclarationOnly": true,
    "outDir": "./dist",
    "declarationDir": "./dist/types",
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "node16",
    "allowJs": true,
    "declaration": true,
    "baseUrl": ".",
