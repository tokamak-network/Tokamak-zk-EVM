  "name": "@tokamak-zk-evm/synthesizer-workspace",
  "private": true,
  "type": "module",
  "workspaces": [
    "node-cli",
    "web-app"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "publish": "node scripts/release.mjs",
    "release": "node scripts/release.mjs",
