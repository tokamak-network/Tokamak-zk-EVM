{
  "name": "@tokamak-zk-evm/synthesizer-node",
  "version": "0.0.10",
  "description": "Node CLI for running the Tokamak zk-EVM synthesizer against JSON transaction snapshot inputs.",
  "keywords": [
    "ethereum",
    "zk-EVM",
    "zero-knowledge",
    "zk-SNARK",
    "cli",
    "synthesizer",
    "state-channel",
    "tokamak",
    "layer2",
    "tokamak-network"
  ],
  "homepage": "https://github.com/tokamak-network/tokamak-zk-evm/tree/main/packages/frontend/synthesizer/node-cli#readme",
  "bugs": {
    "url": "https://github.com/tokamak-network/tokamak-zk-evm/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/tokamak-network/tokamak-zk-evm.git"
  },
  "license": "MIT OR Apache-2.0",
  "author": "Tokamak Network",
  "contributors": [
    "JehyukJang <https://github.com/JehyukJang>",
    "Ale Son <ale@tokamak.network>"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/types/node-cli/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/node-cli/src/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js"
    }
  },
  "bin": {
    "synthesizer": "./dist/cjs/cli/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE-MIT",
    "LICENSE-APACHE",
    "NOTICE"
  ],
  "scripts": {
    "build": "npm run typecheck && npm run build:package",
    "build:package": "node scripts/build-package.mjs",
    "clean": "../../../../config/monorepo-js//cli/clean-package.sh",
    "cli": "tsx --tsconfig tsconfig.dev.json src/cli/index.ts",
    "examples": "tsx --tsconfig tsconfig.dev.json ../../../scripts/examples-runner.ts -- evm",
    "hooks:install": "git config core.hooksPath packages/frontend/synthesizer/node-cli/.githooks",
    "hooks:uninstall": "git config --unset core.hooksPath",
    "lint": "../../../../config/monorepo-js//cli/lint.sh",
    "lint:diff": "../../../../config/monorepo-js//cli/lint-diff.sh",
    "lint:fix": "../../../../config/monorepo-js//cli/lint-fix.sh",
    "synthesize": "tsx --tsconfig tsconfig.dev.json src/cli/index.ts synthesize",
    "synthesizer": "tsx --tsconfig tsconfig.dev.json src/cli/index.ts run",
    "erc20-transfer-l2": "tsx --tsconfig tsconfig.dev.json examples/config-runner.ts erc20-transfer",
    "private-state-mint-l2": "tsx --tsconfig tsconfig.dev.json examples/config-runner.ts private-state-mint",
    "private-state-transfer-l2": "tsx --tsconfig tsconfig.dev.json examples/config-runner.ts private-state-transfer",
    "private-state-redeem-l2": "tsx --tsconfig tsconfig.dev.json examples/config-runner.ts private-state-redeem",
    "manifest-example": "tsx --tsconfig tsconfig.dev.json examples/manifest-runner.ts",
    "test": "tsx --tsconfig tsconfig.dev.json tests/scripts/run-erc20-main-from-configs.ts",
    "test:prep": "tsx --tsconfig tsconfig.dev.json tests/scripts/run-erc20-config-matrix.ts",
    "test:private-state": "tsx --tsconfig tsconfig.dev.json tests/scripts/run-private-state-mint-main-from-configs.ts",
    "test:private-state:prep": "tsx --tsconfig tsconfig.dev.json tests/scripts/run-private-state-mint-config-matrix.ts",
    "test:private-state-transfer": "tsx --tsconfig tsconfig.dev.json tests/scripts/run-private-state-transfer-main-from-configs.ts",
    "test:private-state-transfer:prep": "tsx --tsconfig tsconfig.dev.json tests/scripts/run-private-state-transfer-config-matrix.ts",
    "test:private-state-redeem": "tsx --tsconfig tsconfig.dev.json tests/scripts/run-private-state-redeem-main-from-configs.ts",
    "test:private-state-redeem:prep": "tsx --tsconfig tsconfig.dev.json tests/scripts/run-private-state-redeem-config-matrix.ts",
    "test:node": "npm run -s test",
    "tsc": "npm run typecheck",
    "typecheck": "tsc -p tsconfig.json --pretty false",
    "prepack": "npm run build:package"
  },
  "dependencies": {
    "@ethereumjs/block": "^10.0.0",
    "@ethereumjs/common": "^10.0.0",
    "@ethereumjs/evm": "^10.0.0",
    "@ethereumjs/rlp": "^10.0.0",
    "@ethereumjs/statemanager": "^10.0.0",
    "@ethereumjs/tx": "^10.0.0",
    "@ethereumjs/util": "^10.0.0",
    "@ethereumjs/vm": "^10.0.0",
    "@js-sdsl/ordered-map": "^4.4.2",
    "@noble/curves": "1.9.7",
    "@tokamak-zk-evm/subcircuit-library": "^1.0.0",
    "@types/debug": "^4.1.9",
    "@vitest/coverage-v8": "^2.1.8",
    "@zk-kit/imt": "2.0.0-beta.8",
    "app-root-path": "^3.1.0",
    "commander": "^12.0.0",
    "debug": "^4.3.3",
    "dotenv": "^17.2.0",
    "ethereum-cryptography": "^3.0.0",
    "eventemitter3": "^5.0.1",
    "poseidon-bls12381": "^1.0.2",
    "tokamak-l2js": "^0.1.3",
    "verkle-cryptography-wasm": "^0.4.8",
    "vitest": "^2.1.8"
  },
  "peerDependencies": {
    "ethers": "^6.14.3"
  },
  "peerDependenciesMeta": {
    "ethers": {
      "optional": false
    }
  },
  "devDependencies": {
    "@babel/core": "^7.28.0",
    "@babel/preset-env": "^7.28.0",
    "@paulmillr/trusted-setups": "^0.1.2",
    "@types/benchmark": "^1.0.33",
    "@types/core-js": "^2.5.0",
    "@types/inquirer": "^9.0.9",
    "@types/minimist": "^1.2.2",
    "@types/node": "^22.15.14",
    "@types/node-dir": "^0.0.34",
    "@types/rollup-plugin-visualizer": "^4.2.4",
    "@vercel/ncc": "^0.38.3",
    "babel-loader": "^10.0.0",
    "benchmark": "^2.1.4",
    "esbuild": "^0.25.8",
    "ethers": "^6.14.3",
    "inquirer": "^13.1.0",
    "level": "^8.0.0",
    "mcl-wasm": "^1.5.0",
    "memory-level": "^1.0.0",
    "micro-eth-signer": "^0.11.0",
    "minimist": "^1.2.5",
    "nexe": "^5.0.0-beta.4",
    "node-dir": "^0.1.17",
    "pkg": "^5.8.1",
    "prettier": "^3.5.3",
    "rollup-plugin-visualizer": "^5.12.0",
    "rustbn-wasm": "^0.4.0",
    "solc": "^0.8.1",
    "split": "^1.0.1",
    "ts-loader": "^9.5.2",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "webpack": "^5.101.0",
    "webpack-cli": "^6.0.1"
  },
  "engines": {
    "node": ">=18"
  },
  "pkg": {
    "assets": [
      "node_modules/**/*",
      "qap-compiler/**/*"
    ],
    "scripts": [
      "dist/cjs/**/*.js"
    ],
    "targets": [
      "node18-linux-x64",
      "node18-macos-x64",
      "node18-macos-arm64",
      "node18-win-x64"
    ],
    "outputPath": "bin"
  }
}
