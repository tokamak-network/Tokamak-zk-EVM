{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug trusted-setup (release)",
      "type": "lldb",
      "request": "launch",
      "cargo": {
        "args": ["build", "--release", "-p", "trusted-setup"],
        "filter": { "name": "trusted-setup", "kind": "bin" }
      },
      "program": "${cargo:program}",
      "args": [
        "--output",
        "${workspaceFolder}/setup/output",
        "--fixed-tau"
      ],
      "cwd": "${workspaceFolder}",
      "env": {
        "ICICLE_BACKEND_INSTALL_DIR": "${workspaceFolder}/external-lib/mac/lib/backend",
        "DYLD_LIBRARY_PATH": "${workspaceFolder}/external-lib/mac/lib",
        "LD_LIBRARY_PATH": "${workspaceFolder}/external-lib/mac/lib:${env:LD_LIBRARY_PATH}"
      },  
      "sourceLanguages": ["rust"]
    },
